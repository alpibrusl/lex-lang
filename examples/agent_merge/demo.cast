[0.013804, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.01403, "o", "\r\n  \u001b[1mlex-lang\u001b[0m  ·  Two agents, one function, structural merge\r\n  \u001b[2mConflicts are typed records. Merge is an op in the audit log.\u001b[0m\r\n\r\n"]
[2.020209, "o", "\r\n\u001b[2m"]
[2.020713, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[1m\u001b[36mv0 — initial clamp, published to main\u001b[0m\r\n\u001b[2m"]
