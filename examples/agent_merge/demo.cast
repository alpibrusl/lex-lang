[11.735595, "o", "\u001b[1m\u001b[34m$\u001b[0m  lex branch create feature  &&  lex branch use feature\r\n"]
[12.378496, "o", "created branch `feature` from `main`\r\n"]
[12.392857, "o", "on `feature`\r\n"]
[12.393624, "o", "\r\n"]
[12.903648, "o", "\u001b[1m\u001b[34m$\u001b[0m  cat examples/agent_merge/v1_feature.lex\r\n"]
[13.522382, "o", "fn min2(a :: Int, b :: Int) -> Int { match a < b { true => a, false => b } }\r\nfn max2(a :: Int, b :: Int) -> Int { match a > b { true => a, false => b } }\r\nfn clamp(x :: Int, lo :: Int, hi :: Int) -> Int {\r\n  min2(max2(x, lo), hi)\r\n}\r\n"]
[13.522584, "o", "\r\n"]
[14.325936, "o", "\u001b[1m\u001b[34m$\u001b[0m  lex publish --activate examples/agent_merge/v1_feature.lex --store $STORE\r\n"]
[15.450524, "o", "  → ops: add_function, add_function, modify_body\r\n"]
[15.452512, "o", "\r\n"]
[16.966832, "o", "\r\n\u001b[2m"]
