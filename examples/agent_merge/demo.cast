[43.038637, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"clamp\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"stages\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m3\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"attestations\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m4\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
