[12.721992, "o", "\u001b[1m\u001b[34m$\u001b[0m  grep 'fn fetch' examples/manifesto_effects/dishonest.lex\r\n"]
[13.353038, "o", "fn fetch(url :: Str) -> [io] Bool {\r\n"]
[13.353778, "o", "\r\n"]
[14.164151, "o", "\u001b[1m\u001b[34m$\u001b[0m  lex check examples/manifesto_effects/dishonest.lex\r\n"]
[15.252167, "o", "  error[effect_not_declared]  effect 'net' not declared\r\n    --> examples/manifesto_effects/dishonest.lex:21\r\n\r\n"]
[15.255089, "o", "\u001b[31m\u001b[1m✗  REJECTED\u001b[0m  — [io] signature is a guarantee, not a comment.\r\n"]
[15.2551, "o", "  \u001b[2mA net call in an [io] body is a type error, not a warning.\u001b[0m\r\n\r\n"]
[17.266921, "o", "\u001b[2m"]
[17.267353, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[1m\u001b[32mVALIDATED\u001b[0m\r\n\r\n  The declared effect row IS the contract.\r\n  The type system enforces it before a byte runs.\r\n  Agents can't lie about what they touch.\r\n\r\n\u001b[2m────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
