[0.009613, "o", "\r\n  \u001b[1mlex-lang\u001b[0m  ·  Effects are the contract\r\n  \u001b[2mThe type system is the sandbox.\u001b[0m\r\n\r\n"]
[2.015297, "o", "\r\n\u001b[2m"]
[2.015469, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[1m\u001b[36mhonest.lex — effect row tells the truth\u001b[0m\r\n\u001b[2m"]
