[5.27883, "o", "\u001b[1m\u001b[34m$\u001b[0m  grep 'fn fetch\\|fn double' examples/manifesto_effects/honest.lex\r\n"]
[5.902349, "o", "fn fetch(url :: Str) -> [net] Bool {\r\nfn double(n :: Int) -> Int\r\n"]
[5.902606, "o", "\r\n"]
[6.71081, "o", "\u001b[1m\u001b[34m$\u001b[0m  lex check examples/manifesto_effects/honest.lex\r\n"]
[7.739644, "o", "ok\r\nrequired effects: net\r\nhint: lex run --allow-effects net examples/manifesto_effects/honest.lex <fn> [args]\r\n"]
[7.740088, "o", "\u001b[32m\u001b[1m✓  ok\u001b[0m  — truthful rows accepted\r\n\r\n"]
[9.751601, "o", "\r\n\u001b[2m"]
[9.751862, "o", "────────────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[9.752272, "o", "  \u001b[1m\u001b[36mdishonest.lex — same body, lying signature  →  REJECTED\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
